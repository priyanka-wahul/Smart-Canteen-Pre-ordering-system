<% layout("/layouts/boilerplate") %>
<body>
<h1>Discover our delight Menu</h1>
<br>
<h3><%= category %> Menu</h3>

<div class="menu-container row row-col-lg-4 row-cols-md-3 row-cols-sm-1">
    <% filteredMenu.forEach(menu => { %>
        
        <div class="card row" style="width: 19rem;">
            <img src="<%= menu.image.url %>" class="card-img-top" alt="menuItem_image" 
            style="height: 15rem;">
            
            <div class="card-body">
            <p class="card-text">
            <b><h4><%= menu.name %></h4></b>
             &#8377; <%= menu.price %> &nbsp; &nbsp;

            <a href="/cart/add/<%= menu._id %>"><button class="btn btn-success">Add To Cart</button></a>
            </div> 
            </p>
                       
            <!-- <button>Delete</button> -->
        </div>
        

    <% }) %>

</div>
</body>
